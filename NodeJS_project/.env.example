# Your CRUD API (Backend URL)
API_BASE_URL=https://beyound-chats.onrender.com/api

# Groq LLM Configuration (Get your free key at https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Optional: Use manual fallback URLs if Google search fails
USE_MANUAL_FALLBACK=true

# Optional: Run in test mode (skips Google search & scraping)
TEST_MODE=false

# Logging
LOG_LEVEL=info
